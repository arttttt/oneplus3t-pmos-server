# Maintainer: artem <artembambalov1993@gmail.com>
# Local pmaports package: OnePlus 3T power/display + smart battery-guard helpers.
# Added to the image by build/install.sh via `pmbootstrap install --add op3t-helpers`.
pkgname=op3t-helpers
pkgver=1.0.0
pkgrel=5
pkgdesc="OnePlus 3T power/display CLI + smart battery-hold service + headless defaults"
url="https://github.com/"
arch="noarch"
license="MIT"
options="!check"
depends="tzdata python3"  # tzdata: UTC zoneinfo below; python3: op3t-metrics-web
source="op3t-power
	op3t-battery-guard
	op3t-battery-guard.service
	op3t-battery-guard.default
	op3t-helpers.preset
	wifi-powersave.conf
	op3t-metrics-sample
	op3t-metrics.service
	op3t-metrics.timer
	op3t-metrics-web
	op3t-metrics-web@.service
	op3t-metrics-web.socket
	op3t-metrics.nft
	"

package() {
	# /usr/bin (NOT /usr/local): abuild's postcheck rejects anything under /usr/local.
	install -Dm755 "$srcdir/op3t-power"            "$pkgdir/usr/bin/op3t-power"
	install -Dm755 "$srcdir/op3t-battery-guard"    "$pkgdir/usr/bin/op3t-battery-guard"
	install -Dm644 "$srcdir/op3t-battery-guard.service" \
		"$pkgdir/usr/lib/systemd/system/op3t-battery-guard.service"
	install -Dm644 "$srcdir/op3t-battery-guard.default" \
		"$pkgdir/etc/default/op3t-battery-guard"

	# Enable services on boot via a systemd preset. pmbootstrap runs
	# `systemctl preset-all` at image finalization; the default 99-default.preset
	# is "disable *", so a manually-shipped wants-symlink gets wiped. A preset with
	# prefix < 99 is matched first and makes preset-all create the enable symlink.
	# (A .post-install script can't help: image assembly doesn't run apk scripts.)
	# Enables op3t-battery-guard + systemd-timesyncd (NTP: the clock is wrong on a
	# fresh boot — no persistent RTC on mainline msm8996 — until it syncs online).
	install -Dm644 "$srcdir/op3t-helpers.preset" \
		"$pkgdir/usr/lib/systemd/system-preset/90-op3t-helpers.preset"

	# Disable Wi-Fi power-save (rationale in the conf file).
	install -Dm644 "$srcdir/wifi-powersave.conf" \
		"$pkgdir/etc/NetworkManager/conf.d/90-op3t-wifi-powersave.conf"

	# Metrics: 5-min CSV sampler (timer) + on-demand web viewer on :8088
	# (socket-activated — nothing resident between requests) + the nftables
	# opening for the viewer port.
	install -Dm755 "$srcdir/op3t-metrics-sample" "$pkgdir/usr/bin/op3t-metrics-sample"
	install -Dm755 "$srcdir/op3t-metrics-web"    "$pkgdir/usr/bin/op3t-metrics-web"
	install -Dm644 "$srcdir/op3t-metrics.service" \
		"$pkgdir/usr/lib/systemd/system/op3t-metrics.service"
	install -Dm644 "$srcdir/op3t-metrics.timer" \
		"$pkgdir/usr/lib/systemd/system/op3t-metrics.timer"
	install -Dm644 "$srcdir/op3t-metrics-web@.service" \
		"$pkgdir/usr/lib/systemd/system/op3t-metrics-web@.service"
	install -Dm644 "$srcdir/op3t-metrics-web.socket" \
		"$pkgdir/usr/lib/systemd/system/op3t-metrics-web.socket"
	install -Dm644 "$srcdir/op3t-metrics.nft" \
		"$pkgdir/etc/nftables.d/50_op3t_metrics.nft"

	# Headless server defaults to UTC (no DST; one timescale in logs). musl
	# defaults to UTC already, but make it explicit so timedatectl reports it.
	ln -sf /usr/share/zoneinfo/UTC "$pkgdir/etc/localtime"
	mkdir -p "$pkgdir/etc"; echo UTC > "$pkgdir/etc/timezone"
}
