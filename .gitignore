# Images / binaries — never commit (large, device-specific, rebuildable via build/install.sh)
*.img
*.raw
*.gz
*.dtb
*.apk
*.zip

# Partition backups & build artifacts
backup/
pmos/
firmware/

# Kernel fork working tree (its own git repo: github.com/arttttt/linux-op3t)
kernel/

# Secrets / keys
*_ed25519
*_ed25519.pub
*.key
*.pem

# op3t.sh local state (device host key + last-good IP — device-specific, not source)
.op3t/

# OS cruft
.DS_Store
**/.DS_Store
